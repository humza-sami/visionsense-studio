<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.xronai.visionsense-media-agent</string>
  <key>ProgramArguments</key>
  <array>
    <string>__PROJECT_DIR__/media-agent/build/visionsense-media-agent</string>
    <string>--port</string>
    <string>9010</string>
  </array>
  <key>WorkingDirectory</key>
  <string>__PROJECT_DIR__</string>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>StandardOutPath</key>
  <string>__HOME__/Library/Logs/visionsense-media-agent.log</string>
  <key>StandardErrorPath</key>
  <string>__HOME__/Library/Logs/visionsense-media-agent-error.log</string>
</dict>
</plist>
