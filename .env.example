# Copy to .env (git-ignored) or export in the shell. Credentials live HERE,
# never in site.yaml or code.

# RTSP URL template for the site's NVR; {ch} is replaced per camera.
# Referenced from site.yaml as ${SCHOOL_NVR_TMPL} (name it per site).
SCHOOL_NVR_TMPL=rtsp://USER:PASS@NVR_HOST:554/cam/realmonitor?channel={ch}&subtype=1

# Benchmarks (scripts/benchmark_*.py) use this one:
NVR_TMPL=rtsp://USER:PASS@NVR_HOST:554/cam/realmonitor?channel={ch}&subtype=1

# Cloud sync (only if a supabase sink is enabled in site.yaml):
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_KEY=...
